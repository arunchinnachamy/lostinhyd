# Lost in Hyd Crawler Environment Variables

# PostgreSQL Database (for raw crawled data)
DATABASE_URL=postgres://radar:password@host:port/database?sslmode=require

# Browserless Configuration (for JavaScript-heavy sites like BookMyShow)
# Get your token from https://www.browserless.io/ or use self-hosted
BROWSERLESS_TOKEN=your-browserless-token-here
BROWSERLESS_URL=https://chrome.browserless.io

# Alternative: Self-hosted Browserless (Docker)
# BROWSERLESS_URL=http://localhost:3000

# Optional: Rate limiting (requests per minute)
# CRAWL_RATE_LIMIT=10

# Optional: Request timeout (seconds)
# CRAWL_TIMEOUT=60
