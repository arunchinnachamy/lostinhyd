---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const newsletters = (await getCollection('newsletter')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead 
			title="Newsletter Archive | Lost in Hyd" 
			description="Browse all editions of Lost in Hyd - your weekly guide to Hyderabad hidden gems, local events, and offbeat spots."
			keywords={['Hyderabad newsletter', 'Hyderabad blog', 'Hyderabad events', 'Hyderabad food blog']}
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>Newsletter Archive</h1>
				<p>Every edition of Lost in Hyd — your weekly guide to discovering Hyderabad.</p>
			</section>
			<section class="newsletter-list">
				<ul>
					{
						newsletters.map((post) => (
							<li>
								<a href={`/newsletter/${post.id}/`}>
									<img width={720} height={360} src={post.data.heroImage?.src || '/blog-placeholder-1.jpg'} alt="" />
									<h4 class="title">{post.data.title}</h4>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
									<p class="description">{post.data.description}</p>
									{post.data.area && <span class="area-tag">{post.data.area}</span>}
								</a>
							</li>
						))
						}
					</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		text-align: center;
		padding: 2em 0;
	}
	.intro h1 {
		font-size: 2.5em;
		margin-bottom: 0.5em;
	}
	.newsletter-list ul {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2em;
		list-style: none;
		padding: 0;
		margin: 2em 0;
	}
	.newsletter-list li {
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0,0,0,0.1);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.newsletter-list li:hover {
		transform: translateY(-4px);
		box-shadow: 0 4px 16px rgba(0,0,0,0.15);
	}
	.newsletter-list li a {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.newsletter-list li img {
		width: 100%;
		height: 200px;
		object-fit: cover;
	}
	.newsletter-list li h4 {
		margin: 1em 1em 0.5em;
		font-size: 1.25em;
		color: #2c3e50;
	}
	.newsletter-list li .date {
		margin: 0 1em;
		color: #888;
		font-size: 0.9em;
	}
	.newsletter-list li .description {
		margin: 0.5em 1em 1em;
		color: #555;
	}
	.area-tag {
		display: inline-block;
		background: #2c3e50;
		color: white;
		padding: 0.25em 0.75em;
		border-radius: 4px;
		font-size: 0.8em;
		margin: 0 1em 1em;
	}
</style>
