---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-lost">Lost</span>
          <span class="logo-in">in</span>
          <span class="logo-hyd">Hyd</span>
        </a>
        <p class="footer-tagline">
          Discover the best events, meetups, and happenings in Hyderabad.
        </p>
      </div>
      
      <div class="footer-links">
        <h4>Discover</h4>
        <nav>
          <a href="/">Home</a>
          <a href="/events/">All Events</a>
          <a href="#categories">Categories</a>
        </nav>
      </div>
      
      <div class="footer-links">
        <h4>Areas</h4>
        <nav>
          <a href="/area/banjara-hills/">Banjara Hills</a>
          <a href="/area/jubilee-hills/">Jubilee Hills</a>
          <a href="/area/hitech-city/">Hitech City</a>
          <a href="/area/gachibowli/">Gachibowli</a>
        </nav>
      </div>
      
      <div class="footer-links">
        <h4>Connect</h4>
        <nav>
          <a href="#about">About</a>
          <a href="#newsletter">Newsletter</a>
          <a href="#submit">Submit Event</a>
        </nav>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} Lost in Hyd. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-gray-900);
    color: var(--color-gray-400);
    padding: 3rem 0 1.5rem;
    margin-top: 4rem;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-gray-800);
  }
  
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }
  
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  
  .footer-logo .logo-lost {
    color: var(--color-primary);
    font-family: 'Playfair Display', serif;
  }
  
  .footer-logo .logo-in {
    color: var(--color-gray-500);
    font-size: 1rem;
  }
  
  .footer-logo .logo-hyd {
    color: var(--color-secondary);
    font-family: 'Playfair Display', serif;
  }
  
  .footer-tagline {
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 280px;
  }
  
  .footer-links h4 {
    color: var(--color-white);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  
  .footer-links nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .footer-links a {
    color: var(--color-gray-400);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  
  .footer-links a:hover {
    color: var(--color-white);
  }
  
  .footer-bottom {
    text-align: center;
  }
  
  .footer-bottom p {
    font-size: 0.85rem;
  }
</style>
