---
import EventCard from './EventCard.astro';

export interface Props {
  events: any[];
  columns?: 1 | 2 | 3 | 4;
  emptyMessage?: string;
}

const { events, columns = 3, emptyMessage = 'No events found.' } = Astro.props;

const gridClass = `event-grid event-grid--${columns}`;
---

<div class={gridClass}>
  {events.length > 0 ? (
    events.map(event => <EventCard event={event} />)
  ) : (
    <div class="empty-state">
      <p>{emptyMessage}</p>
    </div>
  )}
</div>

<style>
  .event-grid {
    display: grid;
    gap: 1.5rem;
  }
  
  .event-grid--1 {
    grid-template-columns: 1fr;
  }
  
  .event-grid--2,
  .event-grid--3,
  .event-grid--4 {
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-gray-500);
  }
</style>
