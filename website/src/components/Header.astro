---
export const prerender = false;  // Server-rendered for D1 access

import { getCategories } from '../lib/db.js';

const context = Astro;
const categories = await getCategories(context);
---

<header class="site-header">
  <div class="header-top">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-lost">Lost</span>
        <span class="logo-in">in</span>
        <span class="logo-hyd">Hyd</span>
      </a>
      
      <nav class="main-nav">
        <a href="/">Home</a>
        <a href="/events/">Events</a>
        <a href="#categories">Categories</a>
      </nav>
      
      <button class="mobile-menu-btn" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
  
  <div class="categories-bar">
    <div class="container">
      <nav class="category-nav">
        {categories.slice(0, 8).map(cat => (
          <a href={`/category/${cat.slug}/`} class="category-link">
            {cat.name}
          </a>
        ))}
        <a href="#categories" class="category-link more">More...</a>
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-white);
    box-shadow: var(--shadow);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header-top {
    border-bottom: 1px solid var(--color-gray-200);
  }
  
  .header-top .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 1.5rem;
    font-weight: 700;
  }
  
  .logo-lost {
    color: var(--color-primary);
    font-family: 'Playfair Display', serif;
  }
  
  .logo-in {
    color: var(--color-gray-500);
    font-size: 1rem;
    font-weight: 400;
  }
  
  .logo-hyd {
    color: var(--color-secondary);
    font-family: 'Playfair Display', serif;
  }
  
  .main-nav {
    display: none;
    gap: 1.5rem;
  }
  
  .main-nav a {
    color: var(--color-gray-600);
    font-weight: 500;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  
  .main-nav a:hover {
    color: var(--color-primary);
  }
  
  @media (min-width: 768px) {
    .main-nav {
      display: flex;
    }
    
    .mobile-menu-btn {
      display: none;
    }
  }
  
  .mobile-menu-btn {
    background: none;
    border: none;
    width: 32px;
    height: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 0;
  }
  
  .mobile-menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-gray-700);
    border-radius: 1px;
  }
  
  .categories-bar {
    background: var(--color-gray-900);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  
  .category-nav {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 0;
    white-space: nowrap;
  }
  
  .category-link {
    color: var(--color-gray-300);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: all 0.2s;
  }
  
  .category-link:hover {
    color: var(--color-white);
    background: var(--color-gray-800);
  }
  
  .category-link.more {
    color: var(--color-accent);
  }
</style>
