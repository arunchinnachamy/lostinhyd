---
export interface Props {
  event: {
    id: number;
    title: string;
    slug: string;
    description?: string;
    start_date?: string;
    start_time?: string;
    image_url?: string;
    venue_name?: string;
    venue_name_full?: string;
    area?: string;
    is_free?: boolean;
    price_min?: number;
    price_max?: number;
    currency?: string;
    categories?: string[];
    is_featured?: boolean;
  };
}

const { event } = Astro.props;

function formatDate(dateStr) {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-IN', {
    weekday: 'short',
    day: 'numeric',
    month: 'short'
  });
}

function formatTime(timeStr) {
  if (!timeStr) return '';
  const [hours, minutes] = timeStr.split(':');
  const h = parseInt(hours);
  const ampm = h >= 12 ? 'PM' : 'AM';
  const displayH = h % 12 || 12;
  return `${displayH}:${minutes} ${ampm}`;
}

function formatPrice() {
  if (event.is_free) return 'Free';
  if (!event.price_min && !event.price_max) return 'Price TBA';
  if (event.price_min === event.price_max) {
    return `₹${event.price_min}`;
  }
  if (event.price_min && event.price_max) {
    return `₹${event.price_min} - ₹${event.price_max}`;
  }
  return event.price_min ? `From ₹${event.price_min}` : `Up to ₹${event.price_max}`;
}

const displayVenue = event.venue_name || event.venue_name_full || 'Venue TBA';
const displayArea = event.area || '';
---

<article class="event-card">
  <a href={`/events/${event.slug}/`} class="event-link">
    <div class="event-image">
      {event.image_url ? (
        <img src={event.image_url} alt={event.title} loading="lazy" />
      ) : (
        <div class="event-image-placeholder">
          <span class="placeholder-text">Lost in Hyd</span>
        </div>
      )}
      {event.is_featured && (
        <span class="featured-badge">Featured</span>
      )}
      <span class="price-badge">{formatPrice()}</span>
    </div>
    
    <div class="event-content">
      <div class="event-meta">
        <time class="event-date">
          📅 {formatDate(event.start_date)}
        </time>
        {event.start_time && (
          <span class="event-time">
            🕐 {formatTime(event.start_time)}
          </span>
        )}
      </div>
      
      <h3 class="event-title">{event.title}</h3>
      
      {event.description && (
        <p class="event-description">{event.description.slice(0, 100)}...</p>
      )}
      
      <div class="event-venue">
        📍 <span class="venue-name">{displayVenue}</span>
        {displayArea && (
          <span class="venue-area">, {displayArea}</span>
        )}
      </div>
      
      {event.categories && event.categories.length > 0 && event.categories[0] && (
        <div class="event-categories">
          {event.categories.slice(0, 3).map(cat => (
            <span class="category-tag">{cat}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .event-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  
  .event-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  
  .event-link {
    display: block;
    color: inherit;
  }
  
  .event-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  }
  
  .event-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  
  .event-card:hover .event-image img {
    transform: scale(1.05);
  }
  
  .event-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .placeholder-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 600;
  }
  
  .featured-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-accent);
    color: var(--color-gray-900);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
  }
  
  .price-badge {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    background: rgba(0, 0, 0, 0.75);
    color: var(--color-white);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
  }
  
  .event-content {
    padding: 1rem;
  }
  
  .event-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-gray-600);
  }
  
  .event-title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    color: var(--color-gray-900);
  }
  
  .event-description {
    font-size: 0.85rem;
    color: var(--color-gray-600);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }
  
  .event-venue {
    font-size: 0.85rem;
    color: var(--color-gray-700);
    margin-bottom: 0.75rem;
  }
  
  .venue-area {
    color: var(--color-gray-500);
  }
  
  .event-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .category-tag {
    font-size: 0.7rem;
    color: var(--color-primary);
    background: rgba(99, 102, 241, 0.1);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    font-weight: 500;
  }
</style>
