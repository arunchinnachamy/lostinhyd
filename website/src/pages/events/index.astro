---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EventList from '../../components/EventList.astro';
import { getEvents, getCategories } from '../../lib/db.js';

const allEvents = await getEvents(100, 0);
const categories = await getCategories();

const areas = [...new Set(allEvents.map(e => e.area).filter(Boolean))];

const title = "All Events - Lost in Hyd";
const description = `Browse ${allEvents.length} upcoming events in Hyderabad. Find concerts, meetups, workshops, and more.`;
---

<Layout title={title} description={description}>
  <Header />
  
  <main class="events-page">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">Upcoming Events</h1>
        <p class="page-description">
          Discover {allEvents.length} events happening in Hyderabad
        </p>
      </div>
      
      <div class="filters">
        <div class="filter-group">
          <label for="category-filter">Category</label>
          <select id="category-filter" class="filter-select">
            <option value="">All Categories</option>
            {categories.map(cat => (
              <option value={cat.slug}>{cat.name}</option>
            ))}
          </select>
        </div>
        
        <div class="filter-group">
          <label for="area-filter">Area</label>
          <select id="area-filter" class="filter-select">
            <option value="">All Areas</option>
            {areas.map(area => (
              <option value={area}>{area}</option>
            ))}
          </select>
        </div>
      </div>
      
      <EventList events={allEvents} columns={3} emptyMessage="No upcoming events found." />
    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  .events-page {
    padding: 2rem 0 4rem;
    min-height: 60vh;
  }
  
  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .page-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  
  .page-description {
    color: var(--color-gray-600);
    font-size: 1.1rem;
  }
  
  .filters {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--color-gray-100);
    border-radius: var(--radius-lg);
  }
  
  .filter-group {
    flex: 1;
    min-width: 150px;
  }
  
  .filter-group label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-gray-700);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }
  
  .filter-select {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-gray-300);
    border-radius: var(--radius);
    font-size: 0.95rem;
    background: var(--color-white);
    font-family: inherit;
  }
</style>
